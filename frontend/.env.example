# Tatum Sui RPC — the shared mainnet gateway works with a Tatum API key.
# Used for lightweight app reads (balance). Free tier is rate-limited.
TATUM_SUI_URL=https://sui-mainnet.gateway.tatum.io
TATUM_API_KEY=

# Public Sui mainnet fullnode — used by the Walrus SDK, which is RPC-chatty and
# needs full method coverage (the Tatum free tier is rate-limited / partial).
SUI_FULLNODE_URL=https://fullnode.mainnet.sui.io:443

# Wal server wallet (suiprivkey1...) — generate one; NEVER commit the real value.
WAL_SECRET_KEY=
NEXT_PUBLIC_WAL_ADDRESS=
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Walrus (mainnet). WALRUS_PACKAGE_ID is unused — the SDK derives the on-chain
# contracts from WALRUS_NETWORK; it is kept only to satisfy the env loader.
WALRUS_NETWORK=mainnet
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.mainnet.walrus.space
WALRUS_PACKAGE_ID=0xd84704c17fc870b8764832c535aa6b11f21a95cd6f5bb38a9b07d2cf42220c66
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-mainnet.walrus.space

# Metabolism tuning
WAL_ENERGY_START=10000
WAL_BURN_PER_SEC=0.4

# AI News — OpenRouter (server-side only, proxied via /api/ai-news; key never
# reaches the client). Get a key at https://openrouter.ai/keys. The code appends
# ":online" for web-grounded current news and falls back to the plain model.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
