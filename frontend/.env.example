# Tatum Sui RPC — a dedicated RPC URL self-authenticates (no key); a shared
# gateway (https://sui-testnet.gateway.tatum.io) needs TATUM_API_KEY.
# Used for lightweight app reads (balance, events). Free tier is rate-limited.
TATUM_SUI_URL=https://sui-testnet.gateway.tatum.io
TATUM_API_KEY=

# Public Sui testnet fullnode — used by the Walrus SDK, which is RPC-chatty and
# needs full method coverage (the Tatum free tier is rate-limited / partial).
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443

# Wal server wallet (suiprivkey1...) — generate one; NEVER commit the real value.
WAL_SECRET_KEY=
NEXT_PUBLIC_WAL_ADDRESS=
NEXT_PUBLIC_SUI_NETWORK=testnet

# Walrus (testnet)
WALRUS_NETWORK=testnet
WALRUS_UPLOAD_RELAY_URL=https://upload-relay.testnet.walrus.space
WALRUS_PACKAGE_ID=0xd84704c17fc870b8764832c535aa6b11f21a95cd6f5bb38a9b07d2cf42220c66
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# Metabolism tuning
WAL_ENERGY_START=10000
WAL_BURN_PER_SEC=0.4

# AI News — OpenRouter (server-side only, proxied via /api/ai-news; key never
# reaches the client). Get a key at https://openrouter.ai/keys. The code appends
# ":online" for web-grounded current news and falls back to the plain model.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
