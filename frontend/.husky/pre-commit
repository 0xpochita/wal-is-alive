cd frontend || exit 1

echo "🐳 Wal pre-commit gate — nothing commits that doesn't build"

echo "▶ 1/3 biome check (lint + format)…"
pnpm run lint || { echo "✗ biome check failed — commit blocked"; exit 1; }

echo "▶ 2/3 type-check (tsc --noEmit)…"
pnpm run type-check || { echo "✗ type-check failed — commit blocked"; exit 1; }

echo "▶ 3/3 build (next build)…"
pnpm run build || { echo "✗ build failed — commit blocked"; exit 1; }

echo "✓ all checks passed — commit allowed"
